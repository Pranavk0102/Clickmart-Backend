# ============================================================
#  LOCAL SECRETS TEMPLATE
#  Copy this file to: application-local.properties
#  Fill in the real values — NEVER commit that file to Git
# ============================================================

# Database
DB_URL=jdbc:mysql://127.0.0.1:3306/ecommerce_backend
DB_USERNAME=root
DB_PASSWORD=REPLACE_ME

# JWT — use a strong random 256-bit string
JWT_SECRET=REPLACE_ME

# Mail (Gmail App Password — generate at myaccount.google.com/apppasswords)
MAIL_USERNAME=REPLACE_ME
MAIL_PASSWORD=REPLACE_ME

# Cloudinary
CLOUDINARY_CLOUD_NAME=REPLACE_ME
CLOUDINARY_API_KEY=REPLACE_ME
CLOUDINARY_API_SECRET=REPLACE_ME

# Razorpay
RAZORPAY_KEY_ID=REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
